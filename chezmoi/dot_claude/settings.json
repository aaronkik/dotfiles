{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "DISABLE_TELEMETRY": "1"
  },
  "cleanupPeriodDays": 60,
  "permissions": {
    "allow": [
      "Agent",
      "Bash",
      "Bash(aws sts *)",
      "Bash(find*)",
      "Bash(git*)",
      "Bash(gh*)",
      "Bash(ls*)",
      "Bash(chezmoi*)",
      "Bash(npm run *)",
      "Edit",
      "ExitPlanMode",
      "Glob",
      "Grep",
      "KillShell",
      "LSP",
      "mcp__awslabs_aws-documentation-mcp",
      "mcp__awslabs-dynamodb-mcp-server__list*",
      "mcp__awslabs-dynamodb-mcp-server__describe*",
      "mcp__awslabs-dynamodb-mcp-server__dynamodb_data_modeling",
      "mcp__awslabs-dynamodb-mcp-server__get*",
      "mcp__awslabs-dynamodb-mcp-server__scan",
      "mcp__awslabs-dynamodb-mcp-server__query",
      "mcp__awslabs-aws-api-mcp-server",
      "mcp__awslabs-cloudwatch-mcp-server__describe_log_groups",
      "mcp__awslabs-cloudwatch-mcp-server__analyze_log_group",
      "mcp__awslabs-cloudwatch-mcp-server__execute_log_insights_query",
      "mcp__awslabs-cloudwatch-mcp-server__cancel_logs_insight_query",
      "mcp__awslabs-cloudwatch-mcp-server__get*",
      "mcp__awslabs-cost-explorer-mcp-server",
      "mcp__Context7",
      "mcp__chrome-devtools__*",
      "mcp__github",
      "mcp__knip",
      "NotebookEdit",
      "Read",
      "Skill",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "TodoWrite",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh",
    "padding": 1
  },
  "alwaysThinkingEnabled": true,
  "model": "sonnet[1m]",
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "caveman@caveman": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true,
    "gopls-lsp@claude-plugins-official": true,
    "aws-core@agent-toolkit-for-aws": true,
    "aws-agents@agent-toolkit-for-aws": true,
    "aws-agents-for-devsecops@agent-toolkit-for-aws": true
  },
  "autoMemoryEnabled": false,
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    },
    "agent-toolkit-for-aws": {
      "source": {
        "source": "github",
        "repo": "aws/agent-toolkit-for-aws"
      }
    }
  }
}
