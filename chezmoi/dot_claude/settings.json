{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(aws sts:*)",
      "Bash(find:*)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls:*)",
      "Bash(chezmoi *)",
      "Bash(npm run *)",
      "Edit",
      "Glob",
      "Grep",
      "LS",
      "mcp__awslabs_aws-documentation-mcp",
      "mcp__awslabs-dynamodb-mcp-server__list*",
      "mcp__awslabs-dynamodb-mcp-server__describe*",
      "mcp__awslabs-dynamodb-mcp-server__dynamodb_data_modeling",
      "mcp__awslabs-dynamodb-mcp-server__get*",
      "mcp__awslabs-dynamodb-mcp-server__scan",
      "mcp__awslabs-dynamodb-mcp-server__query",
      "mcp__awslabs-aws-api-mcp-server",
      "mcp__awslabs-cloudwatch-mcp-server__describe_log_groups",
      "mcp__awslabs-cloudwatch-mcp-server__analyze_log_group",
      "mcp__awslabs-cloudwatch-mcp-server__execute_log_insights_query",
      "mcp__awslabs-cloudwatch-mcp-server__cancel_logs_insight_query",
      "mcp__awslabs-cloudwatch-mcp-server__get*",
      "mcp__awslabs-cost-explorer-mcp-server",
      "mcp__Context7",
      "mcp__github",
      "mcp__knip",
      "MultiEdit",
      "NotebookEdit",
      "NotebookRead",
      "Read",
      "Skill",
      "Task",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "alwaysThinkingEnabled": true,
  "model": "opus",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}
